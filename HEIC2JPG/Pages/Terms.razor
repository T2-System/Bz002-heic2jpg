@page "/terms"
@inject ILocalizationService Localizer

<PageTitle>@Localizer.GetString("Legal.TermsTitle")</PageTitle>

<div class="container py-4 py-md-5">
    <div class="mx-auto" style="max-width: 900px;">
        <div class="mb-4">
            <h1 class="mb-2">@Localizer.GetString("Legal.TermsTitle")</h1>
            <p class="text-muted mb-3">@Localizer.GetString("Legal.LastUpdated", LegalDocuments.TermsVersion)</p>
            <p class="lead mb-0">@GetIntro()</p>
        </div>

        @foreach (var legalSection in GetSections())
        {
            <section class="card shadow-sm border-0 mb-3">
                <div class="card-body p-4">
                    <h2 class="h4 mb-3">@legalSection.Title</h2>
                    <p class="mb-3">@legalSection.Body</p>

                    @if (legalSection.Points.Length > 0)
                    {
                        <ul class="mb-0">
                            @foreach (var point in legalSection.Points)
                            {
                                <li class="mb-2">@point</li>
                            }
                        </ul>
                    }
                </div>
            </section>
        }
    </div>
</div>

@code {
    private string GetIntro()
    {
        return GetLanguageFamily() switch
        {
            "en" => "This page summarizes the key rules for using NoTransfer Media Converter. Starting a conversion means you agree to these terms and any later material changes that are clearly announced in the app.",
            "zh" => "本页概述了使用 NoTransfer Media Converter 时需要注意的主要规则。开始转换即表示您同意这些条款，以及应用内明确通知的重要更新。",
            _ => "このページは、NoTransfer Media Converter を利用する際の重要なポイントを要約したものです。変換を開始した時点で、ここに記載した内容と、アプリ内で明示された重要な改定に同意したものとして取り扱います。"
        };
    }

    private LegalSection[] GetSections()
    {
        return GetLanguageFamily() switch
        {
            "en" => GetEnglishSections(),
            "zh" => GetChineseSections(),
            _ => GetJapaneseSections()
        };
    }

    private string GetLanguageFamily()
    {
        return Localizer.CurrentLanguage.StartsWith("en", StringComparison.OrdinalIgnoreCase) ? "en"
            : Localizer.CurrentLanguage.StartsWith("zh", StringComparison.OrdinalIgnoreCase) ? "zh"
            : "ja";
    }

    private static LegalSection[] GetJapaneseSections()
    {
        return
        [
            new(
                "1. 適用範囲と同意",
                "本アプリの利用条件は、ユーザーと株式会社 T2 System との間の本アプリ利用に適用されます。",
                [
                    "アプリへのアクセス、インストール、または利用開始によって、本アプリの利用条件に同意したものとして扱います。",
                    "利用条件に重要な変更がある場合は、次回の変換開始前に再確認をお願いすることがあります。"
                ]),
            new(
                "2. サービスの性質",
                "本アプリは、画像・動画・音声ファイルの変換を主な目的とするブラウザアプリです。",
                [
                    "変換処理そのものは、原則としてユーザー端末のブラウザ内で行われます。",
                    "ブラウザや端末の性能、対応状況、設定によって一部機能が利用できない場合があります。",
                    "FFmpeg 関連スクリプトの読み込みや更新のため、unpkg や jsDelivr などの外部配信元へ通信する場合があります。"
                ]),
            new(
                "3. ユーザーの責任",
                "ユーザーは、自らの責任でファイルを選択し、変換結果を確認する必要があります。",
                [
                    "変換するファイルについて、必要な著作権その他の利用権限を有する場合にのみ利用してください。",
                    "重要なファイルは、変換前後を問わず原本を別途保管してください。",
                    "画質・音質・メタデータ保持・再生互換性は入力形式や環境により変動します。"
                ]),
            new(
                "4. 禁止事項",
                "法令や第三者の権利を侵害する利用は禁止されます。",
                [
                    "違法ファイルの変換、権利侵害、公序良俗違反にあたる利用。",
                    "本アプリまたは外部サービスに過度の負荷を与える行為や不正アクセスの試行。",
                    "適用されるオープンソースライセンスや外部サービス条件に反する利用。"
                ]),
            new(
                "5. 保証の否認と責任制限",
                "当方は、本アプリの継続性、完全性、特定目的適合性、変換結果の品質等を保証しません。",
                [
                    "変換失敗、品質低下、メタデータ欠落、互換性問題などが発生する場合があります。",
                    "外部サービスの障害、仕様変更、提供停止により一部機能が使えなくなる場合があります。",
                    "法令上免責できない場合を除き、当方の責任は直接かつ通常の損害に限られます。"
                ]),
            new(
                "6. 提供者情報",
                "本アプリの提供者は株式会社 T2 System です。",
                [
                    "所在地: 大阪府吹田市西の庄町7-20-101",
                    $"お問い合わせ: {LegalDocuments.ContactUrl}"
                ])
        ];
    }

    private static LegalSection[] GetEnglishSections()
    {
        return
        [
            new(
                "1. Scope and acceptance",
                "These terms govern your use of NoTransfer Media Converter provided by T2 System Co., Ltd.",
                [
                    "Accessing, installing, or starting to use the app is treated as acceptance of these terms.",
                    "If we make a material change, we may ask you to review and accept the updated version before your next conversion."
                ]),
            new(
                "2. Nature of the service",
                "The app is a browser-based tool for converting image, video, and audio files.",
                [
                    "The conversion work itself is generally performed inside your browser on your device.",
                    "Some features depend on browser support, device performance, and local settings.",
                    "The app may contact external CDNs such as unpkg and jsDelivr to load or refresh FFmpeg-related scripts."
                ]),
            new(
                "3. Your responsibilities",
                "You are responsible for the files you choose and for checking the results after conversion.",
                [
                    "Use the app only for files you have the right to process.",
                    "Keep your own backup copies of important files before and after conversion.",
                    "Output quality, metadata retention, and playback compatibility depend on the source file and environment."
                ]),
            new(
                "4. Prohibited use",
                "You may not use the app in ways that violate law or third-party rights.",

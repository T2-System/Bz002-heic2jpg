    private static LegalSection[] GetChineseSections()
    {
        return
        [
            new(
                "1. 适用范围与同意",
                "本条款适用于 T2 System Co., Ltd. 提供的 NoTransfer Media Converter 的使用。",
                [
                    "访问、安装或开始使用本应用，即视为您同意这些条款。",
                    "如条款发生重要变更，我们可能会在您下次开始转换前要求再次确认。"
                ]),
            new(
                "2. 服务性质",
                "本应用是一个在浏览器中运行的图片、视频和音频转换工具。",
                [
                    "实际转换处理原则上在您设备上的浏览器内完成。",
                    "部分功能取决于浏览器支持、设备性能和本地设置。",
                    "为加载或刷新 FFmpeg 相关脚本，应用可能会连接 unpkg、jsDelivr 等外部 CDN。"
                ]),
            new(
                "3. 用户责任",
                "您需要自行选择文件，并在转换后自行确认结果是否符合预期。",
                [
                    "仅可处理您有权使用或转换的文件。",
                    "重要文件请在转换前后自行保留备份。",
                    "输出质量、元数据保留情况和播放兼容性会受到源文件和运行环境影响。"
                ]),
            new(
                "4. 禁止行为",
                "不得以违法或侵害第三方权利的方式使用本应用。",
                [
                    "不得处理违法内容、实施侵权或违反公序良俗。",
                    "不得对本应用或相关服务施加过度负载、滥用或尝试未授权访问。",
                    "不得以违反开源许可证或第三方服务条款的方式使用本应用。"
                ]),
            new(
                "5. 免责声明与责任限制",
                "我们不保证服务持续可用、适合特定目的，也不保证转换结果的质量。",
                [
                    "转换可能失败，也可能出现质量下降、元数据缺失或兼容性问题。",
                    "外部服务的故障、规则变更或停止提供，可能影响部分功能。",
                    "在法律不允许完全免责的范围内，我们的责任仅限于直接且通常发生的损害。"
                ]),
            new(
                "6. 提供者信息",
                "本应用的提供者为 T2 System Co., Ltd.",
                [
                    "地址: 日本大阪府吹田市西之庄町7-20-101",
                    $"联系方式: {LegalDocuments.ContactUrl}"
                ])
        ];
    }

    private sealed record LegalSection(string Title, string Body, string[] Points);
}
